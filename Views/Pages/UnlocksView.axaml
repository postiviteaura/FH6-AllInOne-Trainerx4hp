<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FH6Mod.ViewModels.Pages"
             x:Class="FH6Mod.Views.Pages.UnlocksView"
             x:DataType="vm:UnlocksViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24" Spacing="8">

            <!-- Quick actions -->
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,4">
                <Button Classes="primary" Padding="16,8" FontSize="13"
                        Content="Quick Start"
                        ToolTip.Tip="999M Credits + Free Cars + Autoshow Unlock + All Cars"
                        IsEnabled="{Binding CanToggle}"
                        Command="{Binding QuickStartCommand}" />
                <Button Classes="primary" Padding="16,8" FontSize="13"
                        Content="Max All"
                        ToolTip.Tip="Max Credits, Wheelspins, Super Wheelspins, Skill Points"
                        IsEnabled="{Binding CanToggle}"
                        Command="{Binding MaxAllCommand}" />
            </StackPanel>

            <!-- No game warning -->
            <Border IsVisible="{Binding !CanToggle}"
                    Padding="10,6" CornerRadius="6" BorderThickness="1"
                    Background="#1AFF5555" BorderBrush="#FF5555">
                <TextBlock Text="FH6 is not running — start the game first, then cheats will unlock."
                           FontSize="12" Foreground="#FFB4B4" TextWrapping="Wrap" />
            </Border>

            <!-- Status -->
            <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="10,6" CornerRadius="6" BorderThickness="1"
                    Background="#1A3DDC97" BorderBrush="#3DDC97">
                <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" />
            </Border>

            <!-- ========== PROFILE VALUES ========== -->
            <TextBlock Text="PROFILE VALUES" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextDim}" Margin="0,8,0,0" />

            <!-- Credits -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Credits (CR)" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding CreditsAmountText}" Width="100" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="10K" Padding="6,4" FontSize="11" Command="{Binding SetCreditsCommand}" CommandParameter="10000" />
                    <Button Classes="ghost" Content="100K" Padding="6,4" FontSize="11" Command="{Binding SetCreditsCommand}" CommandParameter="100000" />
                    <Button Classes="ghost" Content="1M" Padding="6,4" FontSize="11" Command="{Binding SetCreditsCommand}" CommandParameter="1000000" />
                    <Button Classes="ghost" Content="100M" Padding="6,4" FontSize="11" Command="{Binding SetCreditsCommand}" CommandParameter="100000000" />
                    <Button Classes="ghost" Content="999M" Padding="6,4" FontSize="11" Command="{Binding SetCreditsCommand}" CommandParameter="999999999" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplyCreditsCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsCreditsOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleCreditsCommand}" />
            </Grid>

            <!-- Wheelspins -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Wheelspins" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding WheelspinsAmountText}" Width="70" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="10" Padding="6,4" FontSize="11" Command="{Binding SetWheelspinsCommand}" CommandParameter="10" />
                    <Button Classes="ghost" Content="50" Padding="6,4" FontSize="11" Command="{Binding SetWheelspinsCommand}" CommandParameter="50" />
                    <Button Classes="ghost" Content="100" Padding="6,4" FontSize="11" Command="{Binding SetWheelspinsCommand}" CommandParameter="100" />
                    <Button Classes="ghost" Content="999" Padding="6,4" FontSize="11" Command="{Binding SetWheelspinsCommand}" CommandParameter="999" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplyWheelspinsCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsWheelspinsOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleWheelspinsCommand}" />
            </Grid>

            <!-- Super Wheelspins -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Super Wheelspins" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding SuperWheelspinsAmountText}" Width="70" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="10" Padding="6,4" FontSize="11" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="10" />
                    <Button Classes="ghost" Content="50" Padding="6,4" FontSize="11" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="50" />
                    <Button Classes="ghost" Content="100" Padding="6,4" FontSize="11" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="100" />
                    <Button Classes="ghost" Content="999" Padding="6,4" FontSize="11" Command="{Binding SetSuperWheelspinsCommand}" CommandParameter="999" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplySuperWheelspinsCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsSuperWheelspinsOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleSuperWheelspinsCommand}" />
            </Grid>

            <!-- Skill Points -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Skill Points" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding SkillPointsAmountText}" Width="90" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="100" Padding="6,4" FontSize="11" Command="{Binding SetSkillPointsCommand}" CommandParameter="100" />
                    <Button Classes="ghost" Content="1K" Padding="6,4" FontSize="11" Command="{Binding SetSkillPointsCommand}" CommandParameter="1000" />
                    <Button Classes="ghost" Content="10K" Padding="6,4" FontSize="11" Command="{Binding SetSkillPointsCommand}" CommandParameter="10000" />
                    <Button Classes="ghost" Content="999K" Padding="6,4" FontSize="11" Command="{Binding SetSkillPointsCommand}" CommandParameter="999999" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplySkillPointsCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsSkillPointsOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleSkillPointsCommand}" />
            </Grid>

            <!-- Sell Payout -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Sell Payout x" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding SellPayoutText}" Width="60" VerticalAlignment="Center" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplySellPayoutCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsSellPayoutOn, Mode=OneWay}"
                              IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleSellPayoutCommand}" />
            </Grid>

            <!-- ========== CAR / PHYSICS ========== -->
            <TextBlock Text="CAR &amp; PHYSICS" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextDim}" Margin="0,8,0,0" />

            <!-- Freeze AI -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Freeze AI Cars" VerticalAlignment="Center" FontSize="13" />
                <TextBlock Grid.Column="1" Text="Stops all AI Drivatars during races" VerticalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource TextDim}" />
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsFreezeAIOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}" Command="{Binding ToggleFreezeAICommand}" />
            </Grid>

            <!-- Teleport -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Teleport" VerticalAlignment="Center" FontSize="13" />
                <TextBlock Grid.Column="1" Text="Teleport to waypoint" VerticalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource TextDim}" />
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsTeleportOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}" Command="{Binding ToggleTeleportCommand}" />
            </Grid>

            <!-- No Clip -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="No Clip" VerticalAlignment="Center" FontSize="13" />
                <TextBlock Grid.Column="1" Text="Disable collision detection" VerticalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource TextDim}" />
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsNoClipOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}" Command="{Binding ToggleNoClipCommand}" />
            </Grid>

            <!-- Gravity Multiplier -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Gravity x" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding GravityMultiplierText}" Width="60" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="0.25" Padding="6,4" FontSize="11" Command="{Binding ApplyGravityMultiplierCommand}" />
                    <Button Classes="ghost" Content="0.5" Padding="6,4" FontSize="11" Command="{Binding ApplyGravityMultiplierCommand}" />
                    <Button Classes="ghost" Content="2.0" Padding="6,4" FontSize="11" Command="{Binding ApplyGravityMultiplierCommand}" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplyGravityMultiplierCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsGravityMultiplierOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}" Command="{Binding ToggleGravityMultiplierCommand}" />
            </Grid>

            <!-- No Water Drag -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="No Water Drag" VerticalAlignment="Center" FontSize="13" />
                <TextBlock Grid.Column="1" Text="Remove water resistance" VerticalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource TextDim}" />
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsNoWaterDragOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}" Command="{Binding ToggleNoWaterDragCommand}" />
            </Grid>

            <!-- Remove Build Cap -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Remove Build Cap" VerticalAlignment="Center" FontSize="13" />
                <TextBlock Grid.Column="1" Text="Remove engine swap power limit" VerticalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource TextDim}" />
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsRemoveBuildCapOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}" Command="{Binding ToggleRemoveBuildCapCommand}" />
            </Grid>

            <!-- ========== WORLD & EVENTS ========== -->
            <TextBlock Text="WORLD &amp; EVENTS" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextDim}" Margin="0,8,0,0" />

            <!-- Time of Day -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Time of Day" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding TimeOfDayText}" Width="60" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="6" Padding="6,4" FontSize="11" Command="{Binding ApplyTimeOfDayCommand}" />
                    <Button Classes="ghost" Content="12" Padding="6,4" FontSize="11" Command="{Binding ApplyTimeOfDayCommand}" />
                    <Button Classes="ghost" Content="18" Padding="6,4" FontSize="11" Command="{Binding ApplyTimeOfDayCommand}" />
                    <Button Classes="ghost" Content="0" Padding="6,4" FontSize="11" Command="{Binding ApplyTimeOfDayCommand}" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplyTimeOfDayCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsTimeOfDayOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}" Command="{Binding ToggleTimeOfDayCommand}" />
            </Grid>

            <!-- Skill Score Multiplier -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Skill Score x" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding SkillScoreMultiplierText}" Width="60" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="5" Padding="6,4" FontSize="11" Command="{Binding ApplySkillScoreMultiplierCommand}" />
                    <Button Classes="ghost" Content="10" Padding="6,4" FontSize="11" Command="{Binding ApplySkillScoreMultiplierCommand}" />
                    <Button Classes="ghost" Content="100" Padding="6,4" FontSize="11" Command="{Binding ApplySkillScoreMultiplierCommand}" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplySkillScoreMultiplierCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsSkillScoreMultiplierOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}" Command="{Binding ToggleSkillScoreMultiplierCommand}" />
            </Grid>

            <!-- Prize Scale -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Prize Scale x" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding PrizeScaleText}" Width="60" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="5" Padding="6,4" FontSize="11" Command="{Binding ApplyPrizeScaleCommand}" />
                    <Button Classes="ghost" Content="10" Padding="6,4" FontSize="11" Command="{Binding ApplyPrizeScaleCommand}" />
                    <Button Classes="ghost" Content="50" Padding="6,4" FontSize="11" Command="{Binding ApplyPrizeScaleCommand}" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplyPrizeScaleCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsPrizeScaleOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}" Command="{Binding TogglePrizeScaleCommand}" />
            </Grid>

            <!-- Race Time Scale -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32">
                <TextBlock Grid.Column="0" Text="Race Time Scale" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding RaceTimeScaleText}" Width="60" VerticalAlignment="Center" />
                    <Button Classes="ghost" Content="0.0" Padding="6,4" FontSize="11" Command="{Binding ApplyRaceTimeScaleCommand}" />
                    <Button Classes="ghost" Content="0.5" Padding="6,4" FontSize="11" Command="{Binding ApplyRaceTimeScaleCommand}" />
                    <Button Classes="ghost" Content="2.0" Padding="6,4" FontSize="11" Command="{Binding ApplyRaceTimeScaleCommand}" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11" Command="{Binding ApplyRaceTimeScaleCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsRaceTimeScaleOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}" Command="{Binding ToggleRaceTimeScaleCommand}" />
            </Grid>

            <!-- ========== ADVANCED CHEATS ========== -->
            <TextBlock Text="ADVANCED" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextDim}" Margin="0,8,0,0" />

            <!-- Acceleration Override -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Acceleration" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding AccelerationText, Mode=TwoWay}" Width="70" FontSize="12" Padding="6,4" />
                    <Button Classes="ghost" Content="Set" Padding="8,4" FontSize="11"
                            IsEnabled="{Binding CanToggle}" Command="{Binding ApplyAccelerationCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsAccelerationOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleAccelerationCommand}" />
            </Grid>

            <!-- Speed Trap Multiplier -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Speed Trap x" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Classes="ghost" Content="5" Padding="6,4" FontSize="11" Command="{Binding ApplySpeedTrapMultiplierCommand}" CommandParameter="5" />
                    <Button Classes="ghost" Content="10" Padding="6,4" FontSize="11" Command="{Binding ApplySpeedTrapMultiplierCommand}" CommandParameter="10" />
                    <Button Classes="ghost" Content="100" Padding="6,4" FontSize="11" Command="{Binding ApplySpeedTrapMultiplierCommand}" CommandParameter="100" />
                    <TextBox Text="{Binding SpeedTrapMultiplierText, Mode=TwoWay}" Width="70" FontSize="12" Padding="6,4" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11"
                            IsEnabled="{Binding CanToggle}" Command="{Binding ApplySpeedTrapMultiplierCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsSpeedTrapMultiplierOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleSpeedTrapMultiplierCommand}" />
            </Grid>

            <!-- Mission Time Scale -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Mission Time" VerticalAlignment="Center" FontSize="13" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Classes="ghost" Content="0 (freeze)" Padding="6,4" FontSize="11" Command="{Binding ApplyMissionTimeScaleCommand}" CommandParameter="0" />
                    <Button Classes="ghost" Content="0.5" Padding="6,4" FontSize="11" Command="{Binding ApplyMissionTimeScaleCommand}" CommandParameter="0.5" />
                    <Button Classes="ghost" Content="2.0" Padding="6,4" FontSize="11" Command="{Binding ApplyMissionTimeScaleCommand}" CommandParameter="2.0" />
                    <TextBox Text="{Binding MissionTimeScaleText, Mode=TwoWay}" Width="70" FontSize="12" Padding="6,4" />
                    <Button Classes="primary" Content="Set" Padding="8,4" FontSize="11"
                            IsEnabled="{Binding CanToggle}" Command="{Binding ApplyMissionTimeScaleCommand}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsMissionTimeScaleOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleMissionTimeScaleCommand}" />
            </Grid>

            <!-- Free Clothing -->
            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="34">
                <TextBlock Grid.Column="0" Text="Free Clothing" VerticalAlignment="Center" FontSize="13" />
                <TextBlock Grid.Column="1" Text="Set all clothing prices to 0" VerticalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource TextDim}" />
                <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                              IsChecked="{Binding IsFreeClothingOn, Mode=OneWay}" IsEnabled="{Binding CanToggle}"
                              Command="{Binding ToggleFreeClothingCommand}" />
            </Grid>

            <!-- ========== BROKEN ========== -->
            <TextBlock Text="BROKEN (game-patched)" FontSize="11" FontWeight="SemiBold"
                       Foreground="#FF5555" Margin="0,8,0,0" />

            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="Drift Score x" VerticalAlignment="Center" FontSize="13" />
                <TextBlock Grid.Column="1" Text="Patched" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextDim}" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Height="32" Opacity="0.5">
                <TextBlock Grid.Column="0" Text="No Skill Break" VerticalAlignment="Center" FontSize="13" />
                <TextBlock Grid.Column="1" Text="Patched" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextDim}" />
                <ToggleSwitch Grid.Column="2" IsEnabled="False" IsChecked="False" />
            </Grid>

            <!-- Engine log -->
            <Border IsVisible="{Binding DiagnosticsMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Padding="10,6" CornerRadius="6" BorderThickness="1"
                    Background="{DynamicResource Surface1Brush}" BorderBrush="{DynamicResource SurfaceBorderBrush}">
                <StackPanel Spacing="4">
                    <TextBlock Text="ENGINE LOG" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextDim}" />
                    <TextBlock Text="{Binding DiagnosticsMessage}" FontSize="11"
                               FontFamily="Consolas, Courier New, monospace"
                               Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
