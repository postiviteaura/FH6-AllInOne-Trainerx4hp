<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:vm="using:FH6Mod.ViewModels.Pages"
             xmlns:b="using:FH6Mod.Behaviors"
             x:Class="FH6Mod.Views.Pages.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="36,28" Spacing="24" b:StaggerEntrance.Enable="True">

            <!-- Header -->
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <Border Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource SurfaceBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <materialIcons:MaterialIcon Kind="{Binding PageIcon}" Width="22" Height="22"
                                                    Foreground="{DynamicResource AccentBrush}" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding PageTitle}" Classes="h1" />
                        <TextBlock Text="{Binding PageSubtitle}" Classes="subtle" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Preferences -->
            <StackPanel Spacing="10">
                <TextBlock Text="PREFERENCES" Classes="eyebrow" />
                <Border Classes="card" Padding="22">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="MotionPlayOutline" Width="22" Height="22"
                                Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="UI animations" Classes="h3" />
                            <TextBlock Text="Card stagger entrance, hover lift, status pulse, page transitions. Saved to disk — kept across launches." Classes="dim" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                                      IsChecked="{Binding AnimationsEnabled, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <!-- Mouse hover glow toggle -->
                <Border Classes="card" Padding="22">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="CursorPointer" Width="22" Height="22"
                                Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Mouse hover glow" Classes="h3" />
                            <TextBlock Text="A soft radial gradient in the accent colour follows your cursor. Disable on weak GPUs if you notice frame drops." Classes="dim" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                                      IsChecked="{Binding MouseGlowEnabled, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <!-- Where prefs live -->
                <Border Classes="card" Padding="22">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="FolderCogOutline" Width="22" Height="22"
                                Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Preferences are saved to" Classes="h3" />
                            <TextBlock Text="{Binding SettingsPath}" Classes="dim" TextWrapping="Wrap"
                                       FontFamily="Consolas, Courier New, monospace" />
                        </StackPanel>
                        <Button Grid.Column="2" Classes="ghost" Content="Open folder"
                                VerticalAlignment="Center"
                                Command="{Binding OpenSettingsFolderCommand}" />
                    </Grid>
                </Border>

                <!-- Accent color picker -->
                <Border Classes="card" Padding="22">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="PaletteOutline" Width="22" Height="22"
                                Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Accent color" Classes="h3" />
                                <TextBlock Classes="dim" TextWrapping="Wrap">
                                    <Run Text="Pick a palette — applies instantly everywhere. Currently:" />
                                    <Run Text="{Binding SelectedAccentName}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                                </TextBlock>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding AccentOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AccentItemVm">
                                        <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                Margin="0,0,10,10" Cursor="Hand"
                                                ToolTip.Tip="{Binding Name}"
                                                Click="OnAccentSwatchClick">
                                            <Border Classes="accentSwatch"
                                                    Classes.selected="{Binding IsSelected}"
                                                    Width="40" Height="40" CornerRadius="999"
                                                    BorderThickness="2" Padding="3">
                                                <Border CornerRadius="999"
                                                        Background="{Binding Base, Converter={StaticResource HexToBrushConverter}}" />
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ABOUT / CREDITS hero card -->
            <Border Classes="card" Padding="28">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="22">
                    <Border Grid.Column="0" Width="96" Height="96" CornerRadius="20" ClipToBounds="True">
                        <Image Source="/Assets/logo.png" Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="FH6 ALL-IN-ONE TRAINER" Classes="eyebrow" />
                        <TextBlock Text="All-in-One Trainer" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="Credits, wheelspins, skill points, free cars — all in one place."
                                   Classes="subtle" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                            <Border Background="{DynamicResource Surface2Brush}"
                                    CornerRadius="999" Padding="10,4">
                                <TextBlock Text="v0.3.0  ·  GPL-3.0" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}" />
                            </Border>
                            <Border Background="{DynamicResource Surface2Brush}"
                                    CornerRadius="999" Padding="10,4">
                                <TextBlock Text=".NET 10  ·  Avalonia 12" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== CREDITS & THANKS ===== -->
            <StackPanel Spacing="10">
                <TextBlock Text="CREDITS &amp; THANKS" Classes="eyebrow" />

                <!-- paris' club — the mods this trainer is built on -->
                <Border Classes="card" Padding="22">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10"
                                Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="Heart" Width="22" Height="22"
                                                        Foreground="{DynamicResource AccentBrush}"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Classes="h3">
                                <Run Text="paris' club" Foreground="{DynamicResource AccentBrush}" />
                                <Run Text=" — the actual mods" Foreground="{DynamicResource TextPrimary}" />
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Classes="dim"
                                       Text="All core cheats by paris' club: runtime hooks, SQL features, CRC bypass, code caves, memory injection. Original UI by changcheng967. Improved with Max All, Unlock Everything, Quick Start, and preset buttons." />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Border Background="{DynamicResource Surface2Brush}" CornerRadius="999" Padding="8,3">
                                    <TextBlock Text="discord.gg/WSd3bRNJuJ" FontSize="11"
                                               Foreground="{DynamicResource TextSecondary}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Reloaded -->
                <Border Classes="card" Padding="22">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10"
                                Background="{DynamicResource Surface2Brush}">
                            <materialIcons:MaterialIcon Kind="LightningBolt" Width="22" Height="22"
                                                        Foreground="{DynamicResource AccentBrush}"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Classes="h3">
                                <Run Text="Reloaded.Memory" Foreground="{DynamicResource AccentBrush}" />
                                <Run Text=" — SIMD-accelerated AOB scanner" Foreground="{DynamicResource TextPrimary}" />
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Classes="dim"
                                       Text="Ultra-fast AOB scanner used by the memory engine — scans the 49 MB FH6 binary in milliseconds." />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Settings list -->
            <ItemsControl ItemsSource="{Binding Features}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="320" ItemHeight="92" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:FeatureRow">
                        <Border Classes="card" Margin="0,0,12,12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{Binding Name}" Classes="h3" />
                                    <TextBlock Text="{Binding Hint}" Classes="dim" TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Grid.Column="1" VerticalAlignment="Top" Padding="8,3" CornerRadius="999"
                                        Background="{Binding Status, Converter={StaticResource StatusBgConverter}}">
                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusLabelConverter}}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{Binding Status, Converter={StaticResource StatusFgConverter}}" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Footer -->
            <TextBlock Classes="dim" TextAlignment="Center" Margin="0,12" TextWrapping="Wrap">
                <Run Text="Improved by " />
                <Run Text="All-in-One Trainer" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                <Run Text=" · original UI by Chaarkor, cheats by paris' club · 2026 · Forza Horizon 6 · Single-player only" />
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
