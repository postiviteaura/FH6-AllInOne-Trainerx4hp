<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FH6Mod.ViewModels"
        xmlns:pages="using:FH6Mod.Views.Pages"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="880" d:DesignHeight="620"
        Width="880" Height="620"
        MinWidth="720" MinHeight="500"
        x:Class="FH6Mod.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="FH6 All-in-One Trainer"
        Background="{DynamicResource Surface0Brush}"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/logo.png">

    <Grid RowDefinitions="Auto,*">

        <!-- Title bar -->
        <Border Grid.Row="0" Padding="16,8"
                Background="{DynamicResource Surface0Brush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="FH6 Trainer" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentVersionText}" Classes="dim" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="{DynamicResource StatusErr}"
                             VerticalAlignment="Center" />
                    <TextBlock Text="{Binding GameStatusText}" Classes="subtle" VerticalAlignment="Center" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Single scrollable page with all sections -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <pages:UnlocksView DataContext="{Binding UnlocksPage}" />
                <Border Height="1" Background="{DynamicResource SurfaceBorderBrush}" Margin="20,0" />
                <pages:DatabaseView DataContext="{Binding DatabasePage}" />
                <Border Height="1" Background="{DynamicResource SurfaceBorderBrush}" Margin="20,0" />
                <pages:SettingsView DataContext="{Binding SettingsPage}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
